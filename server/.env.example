# ── Database ─────────────────────────────────────────────────────────────────
# Local / XAMPP development — use these:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=communicare

# Railway production — Railway injects MYSQL_URL automatically when you
# add a MySQL plugin to your service. You do NOT need to set it manually.
# MYSQL_URL=mysql://user:password@host:port/database

# ── Application ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=communicare_jwt_secret_change_in_production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL in production (no trailing slash)
# Example: CLIENT_URL=https://communicare.vercel.app
CLIENT_URL=http://localhost:5173

# ── Email verification links ─────────────────────────────────────────────────
# Set to your Vercel frontend URL in production
APP_URL=http://localhost:5173

# ── SMTP (optional in dev — leave blank to use Ethereal auto-account) ────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=yourpassword

# ── AI Summary ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional model override (default: claude-sonnet-4-5). Opus is more capacity-
# constrained and was observed returning HTTP 529 overloaded_error in testing.
# ANTHROPIC_MODEL=claude-sonnet-4-5
